{
  "description": "Rules merged into ~/.claude/settings.json permissions by setup.sh. Allows are needed because skill command-frontmatter invocations do not trigger PreToolUse hooks. Denies are fallbacks for critical operations.",
  "allow": [
    "Bash(~/.claude/skills/*/scripts/*.sh)",
    "Bash(~/.claude/skills/*/scripts/*.sh *)",
    "Bash(rsync *)",
    "Read",
    "Write",
    "Edit",
    "Glob",
    "Grep",
    "NotebookEdit",
    "WebFetch",
    "WebSearch",
    "Agent",
    "Skill",
    "ToolSearch",
    "ListMcpResourcesTool",
    "ReadMcpResourceTool",
    "LSP",
    "TaskCreate",
    "TaskGet",
    "TaskList",
    "TaskOutput",
    "TaskStop",
    "TaskUpdate",
    "TodoWrite",
    "AskUserQuestion",
    "EnterPlanMode",
    "ExitPlanMode",
    "EnterWorktree",
    "ExitWorktree",
    "CronCreate",
    "CronDelete",
    "CronList",
    "mcp__claude_ai_Atlassian_Rovo",
    "mcp__claude_ai_Figma",
    "mcp__claude_ai_Fireflies",
    "mcp__claude_ai_Gmail",
    "mcp__claude_ai_Google_Calendar",
    "mcp__claude_ai_Google_Drive",
    "mcp__claude_ai_Linear",
    "mcp__claude_ai_Notion",
    "mcp__claude_ai_Pylon",
    "mcp__claude_ai_Slack",
    "mcp__claude_ai_monday_com",
    "mcp__datadog",
    "mcp__playwright",
    "mcp__posthog",
    "mcp__superset",
    "mcp__unblocked"
  ],
  "deny": [
    "Bash(sudo *)",
    "Bash(rm -rf /)",
    "Bash(rm -rf ~*)",
    "Bash(rm -fr ~*)",
    "Bash(rm -r ~*)"
  ],
  "removed": [
    "mcp__*"
  ]
}
