# {{ project_name }}
{% raw %}
set dotenv-load := true

# Discover free ports and write .env files (run once before starting, or to resolve port conflicts)
setup:
    uv run python scripts/setup.py

# Start everything (Postgres + API + web dev servers). Tears down Docker on exit.
# Re-runs setup automatically if .env is missing or DB port is already taken.
start:
    #!/usr/bin/env bash
    set -euo pipefail
    # Capture external DATABASE_URL before loading .env — if set (e.g., CI service container),
    # we skip Docker entirely and let the API connect to the external DB directly.
    _ext_db="${DATABASE_URL:-}"
    # Auto-discover ports on first run
    if [ ! -f .env ]; then
        echo "No .env found — running setup to discover ports..."
        just setup
    fi
    # Load .env so we can read the ports in this script
    set -a; source .env; set +a
    if [ -z "$_ext_db" ]; then
        db_port="${DB_PORT:-5432}"
        # If DB_PORT is already taken by something other than our container, rediscover
        if ! python3 -c "import socket; s=socket.socket(socket.AF_INET,socket.SOCK_STREAM); s.bind(('', ${db_port})); s.close()" 2>/dev/null; then
            if ! docker compose ps --quiet postgres 2>/dev/null | grep -q .; then
                echo "Port ${db_port} is already taken. Re-running setup to find free ports..."
                just setup
                set -a; source .env; set +a
            fi
        fi
        docker compose up -d
    fi
    set +e
    api_pid="" web_pid=""
    cleanup() {
        echo ""; echo "Shutting down..."
        [ -n "$api_pid" ] && kill "$api_pid" 2>/dev/null
        [ -n "$web_pid" ] && kill "$web_pid" 2>/dev/null
        wait 2>/dev/null
        docker compose down 2>/dev/null
    }
    trap cleanup EXIT
    trap 'exit 0' INT TERM
    echo ""
    echo "  Web:      http://localhost:${WEB_PORT:-3000}"
    echo "  API:      http://localhost:${API_PORT:-8000}"
    echo "  API docs: http://localhost:${API_PORT:-8000}/docs"
    echo ""
    (cd apps/api && uv run uvicorn src.main:app --reload --port "${API_PORT:-8000}" 2> >(grep -v "Interrupted by SIGINT" >&2) | sed 's/^/[api] /') &
    api_pid=$!
    (cd apps/web && bash scripts/dev.sh 2>&1 | sed 's/^/[web] /') &
    web_pid=$!
    wait 2>/dev/null

# Run all tests
test:
    uv run pytest
    cd apps/web && pnpm test

# Run API tests only
test-api:
    uv run pytest

# Run web tests only
test-web:
    cd apps/web && pnpm test

# Lint all code
lint:
    uv run ruff check .
    npx @biomejs/biome check apps/web/

# Format all code
format:
    uv run ruff format .
    npx @biomejs/biome check --write apps/web/

# Check formatting without modifying files
format-check:
    uv run ruff format --check .
    npx @biomejs/biome check apps/web/

# Apply database migrations
db-migrate:
    cd apps/api && uv run alembic upgrade head

# Create a new migration revision
db-revision message:
    cd apps/api && uv run alembic revision --autogenerate -m "{{message}}"

# Install all dependencies
install:
    uv sync
    cd apps/web && pnpm install
{% endraw %}
