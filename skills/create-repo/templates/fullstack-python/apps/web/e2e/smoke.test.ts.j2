import { test, expect } from "@playwright/test"
import { HomePage } from "./pages/home.page"

test.describe("smoke tests", () => {
  test("app loads and shows heading", async ({ page }) => {
    const home = new HomePage(page)
    await home.navigate()
    await expect(await home.getHeading()).toHaveText("{{ project_name }}", { exact: true })
  })

  test("API health endpoint responds via proxy", async ({ request }) => {
    const response = await request.get("/api/health")
    expect(response.ok()).toBeTruthy()
    const body = await response.json()
    expect(body.status).toBe("ok")
  })

  test("health status renders in the browser", async ({ page }) => {
    const home = new HomePage(page)
    await home.navigate()
    await home.waitForApiReady()
    await expect(await home.getApiStatus()).toContainText("ok")
  })
})
