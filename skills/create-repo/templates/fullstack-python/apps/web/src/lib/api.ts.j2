const API_BASE = "/api"

export async function apiFetch<T>(path: string, init?: RequestInit): Promise<T> {
  const response = await fetch(`${API_BASE}${path}`, {
    headers: { "Content-Type": "application/json", ...init?.headers },
    ...init,
  })
  if (!response.ok) {
    throw new Error(`API error: ${response.status} ${response.statusText}`)
  }
  return response.json()
}

export const api = {
  health: () => apiFetch<{ status: string }>("/health"),
  users: {
    list: () => apiFetch<Array<{ id: number; name: string; email: string }>>("/users/"),
    get: (id: number) => apiFetch<{ id: number; name: string; email: string }>(`/users/${id}`),
    create: (data: { name: string; email: string }) =>
      apiFetch<{ id: number; name: string; email: string }>("/users/", {
        method: "POST",
        body: JSON.stringify(data),
      }),
    update: (id: number, data: { name?: string; email?: string }) =>
      apiFetch<{ id: number; name: string; email: string }>(`/users/${id}`, {
        method: "PATCH",
        body: JSON.stringify(data),
      }),
    delete: (id: number) =>
      apiFetch<{ ok: boolean }>(`/users/${id}`, { method: "DELETE" }),
  },
}
