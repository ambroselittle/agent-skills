#!/usr/bin/env python3
"""Discover free ports and write .env files for local development.

Run via: uv run python scripts/setup.py
Or via:  just setup
"""

from __future__ import annotations

import fcntl
import json
import socket
import subprocess
from datetime import UTC, datetime
from pathlib import Path

# Project constants (substituted at scaffold time)
_DATABASE_NAME = "{{ project_name }}_dev"
_PROJECT_SLUG = "{{ project_name }}"

{% raw %}
def find_free_port(start: int, end: int, exclude: set[int] | None = None) -> int:
    """Find the first free TCP port in [start, end], skipping excluded ports."""
    for port in range(start, end + 1):
        if exclude and port in exclude:
            continue
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("", port))
                return port
            except OSError:
                continue
    raise RuntimeError(f"No free port found in range {start}–{end}")


def _worktree_slug(root: Path) -> str:
    """Return a short identifier for the current git worktree (or 'main')."""
    try:
        git_dir = subprocess.check_output(
            ["git", "rev-parse", "--git-dir"],
            cwd=root,
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
        if "worktrees/" in git_dir:
            return git_dir.split("worktrees/")[1].split("/")[0]
    except Exception:
        pass
    return "main"


def main() -> None:
    root = Path(__file__).parent.parent.resolve()

    # Allocate ports under a global registry lock to prevent cross-project collisions
    # when multiple scaffolding runs happen concurrently.
    registry_dir = Path.home() / ".agent-skills"
    registry_dir.mkdir(parents=True, exist_ok=True)
    registry_path = registry_dir / ".port-registry.json"
    lock_path = registry_dir / ".port-registry.lock"

    with open(lock_path, "w") as _lock:
        fcntl.flock(_lock, fcntl.LOCK_EX)

        # Read registry and clean up stale entries (deleted project dirs)
        registry: dict = {}
        if registry_path.exists():
            try:
                registry = json.loads(registry_path.read_text())
            except Exception:
                registry = {}
        registry = {k: v for k, v in registry.items() if Path(v.get("dir", "")).exists()}

        # Collect ports already claimed by other projects
        taken: set[int] = set()
        for entry in registry.values():
            for key in ("DB_PORT", "API_PORT", "WEB_PORT"):
                if key in entry:
                    taken.add(entry[key])

        db_port = find_free_port(5432, 5499, taken)
        taken.add(db_port)
        api_port = find_free_port(8000, 8099, taken)
        taken.add(api_port)
        has_web = (root / "apps" / "web").is_dir()
        web_port = find_free_port(3000, 3099, taken) if has_web else None

        registry[_PROJECT_SLUG] = {
            "DB_PORT": db_port,
            "API_PORT": api_port,
            **({} if web_port is None else {"WEB_PORT": web_port}),
            "dir": str(root),
            "updated": datetime.now(UTC).isoformat(),
        }
        registry_path.write_text(json.dumps(registry, indent=2) + "\n")

    database_url = f"postgresql://postgres:postgres@localhost:{db_port}/{_DATABASE_NAME}"
    compose_name = f"{_PROJECT_SLUG}-{_worktree_slug(root)}"

    # Root .env — read by docker-compose and `just` recipes
    env_lines = [
        f"DB_PORT={db_port}",
        f"API_PORT={api_port}",
    ]
    if web_port is not None:
        env_lines.append(f"WEB_PORT={web_port}")
    env_lines += [
        f"DATABASE_URL={database_url}",
        f"COMPOSE_PROJECT_NAME={compose_name}",
    ]
    (root / ".env").write_text("\n".join(env_lines) + "\n")
    port_summary = f"DB_PORT={db_port}, API_PORT={api_port}"
    if web_port is not None:
        port_summary += f", WEB_PORT={web_port}"
    print(f"Wrote .env  ({port_summary})")

    # apps/api/.env — picked up by uvicorn and alembic
    api_dir = root / "apps" / "api"
    if api_dir.exists():
        (api_dir / ".env").write_text(f"DATABASE_URL={database_url}\nPORT={api_port}\n")
        print("Wrote apps/api/.env")

    print("\nSetup complete. Run `just start` to start.")


if __name__ == "__main__":
    main()
