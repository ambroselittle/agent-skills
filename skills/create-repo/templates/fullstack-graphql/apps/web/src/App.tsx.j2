import { ApolloProvider } from "@apollo/client"
import { useHealthQuery } from "./generated/graphql"
import { client } from "./lib/apollo"

function AppContent() {
  const { data, loading } = useHealthQuery()

  return (
    <div>
      <h1>{{ project_name }}</h1>
      <p>API status: {loading ? "loading..." : data?.health ?? "error"}</p>
    </div>
  )
}

export function App() {
  return (
    <ApolloProvider client={client}>
      <AppContent />
    </ApolloProvider>
  )
}
