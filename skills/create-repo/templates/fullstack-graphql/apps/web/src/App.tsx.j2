import { ApolloProvider, useQuery } from "@apollo/client/react"
import { graphql } from "./generated/gql"
import { client } from "./lib/apollo"

const HEALTH_QUERY = graphql(`
  query Health {
    health
  }
`)

function AppContent() {
  const { data, loading } = useQuery(HEALTH_QUERY)

  return (
    <div>
      <h1>{{ project_name }}</h1>
      <p>API status: {loading ? "loading..." : data?.health ?? "error"}</p>
    </div>
  )
}

export function App() {
  return (
    <ApolloProvider client={client}>
      <AppContent />
    </ApolloProvider>
  )
}
