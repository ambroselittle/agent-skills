{
  "name": "{{ scope }}/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "{{ scope }}/api": "workspace:*",
    "{{ scope }}/types": "workspace:*",
    "@apollo/client": "{{ versions.apollo_client }}",
    "@graphql-typed-document-node/core": "{{ versions.graphql_typed_document_node_core }}",
    "graphql": "{{ versions.graphql }}",
    "react": "{{ versions.react }}",
    "react-dom": "{{ versions.react_dom }}"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "{{ versions.graphql_codegen_cli }}",
    "@graphql-codegen/introspection": "{{ versions.graphql_codegen_introspection }}",
    "@graphql-codegen/near-operation-file-preset": "{{ versions.graphql_codegen_near_operation_file_preset }}",
    "@graphql-codegen/typed-document-node": "{{ versions.graphql_codegen_typed_document_node }}",
    "@graphql-codegen/typescript": "{{ versions.graphql_codegen_typescript }}",
    "@graphql-codegen/typescript-operations": "{{ versions.graphql_codegen_typescript_operations }}",
    "@types/react": "{{ versions.types_react }}",
    "@types/react-dom": "{{ versions.types_react_dom }}",
    "@vitejs/plugin-react": "{{ versions.vitejs_plugin_react }}",
    "tailwindcss": "{{ versions.tailwindcss }}",
    "@tailwindcss/vite": "{{ versions.tailwindcss_vite }}",
    "typescript": "{{ versions.typescript }}",
    "vite": "{{ versions.vite }}",
    "vitest": "{{ versions.vitest }}",
    "@playwright/test": "{{ versions.playwright_test }}",
    "@testing-library/react": "{{ versions.testing_library_react }}",
    "@testing-library/jest-dom": "{{ versions.testing_library_jest_dom }}",
    "dotenv": "{{ versions.dotenv }}",
    "jsdom": "{{ versions.jsdom }}"
  }
}
