{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate:schema": {
      "cache": false
    },
    "codegen": {
      "dependsOn": ["^generate:schema"],
      "outputs": ["src/generated/gql/**"]
    },
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build", "codegen"]
    },
    "typecheck": {
      "dependsOn": ["^build", "codegen"]
    },
    "lint": {},
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    }
  }
}
