{
  "name": "{{ scope }}/api",
  "private": true,
  "type": "module",
  "exports": {
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "{{ scope }}/db": "workspace:*",
    "{{ scope }}/types": "workspace:*",
    "@hono/node-server": "{{ versions.hono_node_server }}",
    "@hono/trpc-server": "{{ versions.hono_trpc_server }}",
    "@trpc/server": "{{ versions.trpc_server }}",
    "hono": "{{ versions.hono }}",
    "zod": "latest"
  },
  "devDependencies": {
    "tsx": "latest",
    "typescript": "{{ versions.typescript }}",
    "vitest": "{{ versions.vitest }}"
  }
}
