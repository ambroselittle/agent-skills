    "tailwindcss": "{{ versions.tailwindcss }}",
    "@tailwindcss/vite": "{{ versions.tailwindcss_vite }}",
    "typescript": "{{ versions.typescript }}",
    "vite": "{{ versions.vite }}",
    "vitest": "{{ versions.vitest }}",
    "@playwright/test": "{{ versions.playwright_test }}",
