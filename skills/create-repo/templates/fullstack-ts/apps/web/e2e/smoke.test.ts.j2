import { test, expect } from "@playwright/test"
import { HomePage } from "./pages/home.page"

test.describe("smoke tests", () => {
  test("app loads and shows heading", async ({ page }) => {
    const home = new HomePage(page)
    await home.navigate()
    await expect(await home.getHeading()).toHaveText("{{ project_name }}", { exact: true })
  })

  test("API health endpoint responds", async ({ page }) => {
    test.setTimeout(30_000)
    const home = new HomePage(page)
    await home.navigate()
    await home.waitForApiReady()
    await expect(await home.getApiStatus()).toContainText("ok")
  })
})
